{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evaluation_schema_v1.0",
  "title": "에이전트 오케스트레이션 비교 실험 — 평가 스키마",
  "description": "논문: 대화형 문서 QA에서 에이전트 오케스트레이션 구조에 따른 정확도와 운영 비용 비교 | 저자: 문근영·김희경·주승현·허대영 (국민대학교) | v1.0 — 실험 기간 중 수정 금지",
  "version": "1.0",

  "_comment_structure": [
    "본 파일은 세 가지 스키마로 구성된다.",
    "1. agent_response_schema : 에이전트가 생성해야 할 출력 JSON 구조 (tool_api.validate_output 의 검증 기준)",
    "2. run_log_schema        : 실행 1건(1 question × 1 framework × 1 run_index)의 로그 레코드 구조",
    "3. evaluation_rules      : 정답 판정 기준, 지표 정의, 허용오차, 수동 검수 기준"
  ],

  "experiment_metadata": {
    "total_questions"   : 40,
    "datasets"          : ["Korean_Admin_QA", "FinQA"],
    "frameworks"        : ["LangChain", "CrewAI", "LangGraph"],
    "runs_per_question" : 3,
    "total_runs"        : 360,
    "llm"               : "gpt-4o-mini",
    "temperature"       : 0,
    "max_tokens"        : 1024,
    "experiments": {
      "실험1": { "dataset": "Korean_Admin_QA", "task_type": "single_doc_extraction",       "question_ids": ["Q001","Q002","Q003","Q004","Q005","Q006","Q007","Q008","Q009","Q010"] },
      "실험2": { "dataset": "Korean_Admin_QA", "task_type": "complex_condition_judgment",   "question_ids": ["Q011","Q012","Q013","Q014","Q015","Q016","Q017","Q018","Q019","Q020"] },
      "실험3": { "dataset": "FinQA",           "task_type": "single_evidence_numeric",      "question_ids": ["Q021","Q022","Q023","Q024","Q025","Q026","Q027","Q028","Q029","Q030"] },
      "실험4": { "dataset": "FinQA",           "task_type": "multi_step_calculation",       "question_ids": ["Q031","Q032","Q033","Q034","Q035","Q036","Q037","Q038","Q039","Q040"] }
    }
  },

  "agent_response_schema": {
    "description": "에이전트가 각 질의에 대해 반환해야 하는 JSON 출력 구조. tool_api.validate_output()의 검증 기준과 동일.",
    "type": "object",
    "required": ["question_id","framework","dataset","task_type","final_answer","evidence","confidence","is_answered"],
    "additionalProperties": false,
    "properties": {
      "question_id": {
        "type"       : "string",
        "pattern"    : "^Q\\d{3}$",
        "description": "실험 질문 ID. Q001~Q040 형식."
      },
      "framework": {
        "type"       : "string",
        "enum"       : ["LangChain", "CrewAI", "LangGraph"],
        "description": "응답을 생성한 프레임워크 이름."
      },
      "dataset": {
        "type"       : "string",
        "enum"       : ["Korean_Admin_QA", "FinQA"],
        "description": "질문이 속한 데이터셋."
      },
      "task_type": {
        "type"       : "string",
        "enum"       : ["single_doc_extraction","complex_condition_judgment","single_evidence_numeric","multi_step_calculation"],
        "description": "과업 유형."
      },
      "final_answer": {
        "type"       : "string",
        "minLength"  : 1,
        "maxLength"  : 200,
        "description": "최종 답변 문자열. 단위(%, $, 천원 등) 포함. 2문장 이내."
      },
      "evidence": {
        "type"       : "array",
        "minItems"   : 1,
        "maxItems"   : 3,
        "items"      : { "type": "string", "minLength": 1 },
        "description": "답변의 근거가 된 문서 원문 발췌. 1~3개."
      },
      "calculation": {
        "type"       : ["string", "null"],
        "description": "수치 계산 과정 문자열. 단일: '5829 - 5735 = 94'. 다단계: 'Step 1: ... / Step 2: ...'. 계산 없으면 null.",
        "examples"   : [
          "5829 - 5735 = 94",
          "Step 1: 153.7 - 139.9 = 13.8 / Step 2: 13.8 / 139.9 = 0.09864"
        ]
      },
      "confidence": {
        "type"             : "number",
        "minimum"          : 0.0,
        "maximum"          : 1.0,
        "description"      : "에이전트 자기평가 신뢰도 (0.0~1.0). 명확한 근거 → 0.9 이상 / 추론 필요 → 0.7~0.9 / 불확실 → 0.7 미만."
      },
      "is_answered": {
        "type"       : "boolean",
        "description": "문서 내 근거로 답변 가능하면 true, 근거 없어 답변 불가면 false."
      }
    },

    "examples": [
      {
        "_label"      : "실험1 — 단일 문서 정보 추출 (Q001)",
        "question_id" : "Q001",
        "framework"   : "LangChain",
        "dataset"     : "Korean_Admin_QA",
        "task_type"   : "single_doc_extraction",
        "final_answer": "44.9%",
        "evidence"    : ["70대 이상 스마트폰 보유율은 44.9% 불과 ('20년)"],
        "calculation" : null,
        "confidence"  : 0.98,
        "is_answered" : true
      },
      {
        "_label"      : "실험2 — 복합 조건 판단 (Q011)",
        "question_id" : "Q011",
        "framework"   : "CrewAI",
        "dataset"     : "Korean_Admin_QA",
        "task_type"   : "complex_condition_judgment",
        "final_answer": "검사 및 상담 완료 후 검사결과를 아동 가구에 개별 통보",
        "evidence"    : ["아동건강검진 사후관리: 검사 및 상담 완료 후 검사결과를 아동 가구에 개별 통보"],
        "calculation" : null,
        "confidence"  : 0.95,
        "is_answered" : true
      },
      {
        "_label"      : "실험3 — 단일 근거 수치 질의 (Q021)",
        "question_id" : "Q021",
        "framework"   : "LangGraph",
        "dataset"     : "FinQA",
        "task_type"   : "single_evidence_numeric",
        "final_answer": "94.0",
        "evidence"    : ["2015 net revenue: $5,829 million", "2014 net revenue: $5,735 million"],
        "calculation" : "5829 - 5735 = 94.0",
        "confidence"  : 0.97,
        "is_answered" : true
      },
      {
        "_label"      : "실험4 — 다단계 계산/추론 (Q031)",
        "question_id" : "Q031",
        "framework"   : "LangChain",
        "dataset"     : "FinQA",
        "task_type"   : "multi_step_calculation",
        "final_answer": "0.09864",
        "evidence"    : ["Cash flow hedges 2011: 153.7", "Cash flow hedges 2010: 139.9"],
        "calculation" : "Step 1: 153.7 - 139.9 = 13.8 / Step 2: 13.8 / 139.9 = 0.09864",
        "confidence"  : 0.93,
        "is_answered" : true
      }
    ]
  },

  "run_log_schema": {
    "description": "실행 1건(1 question × 1 framework × 1 run_index)의 결과 로그 레코드. results_{framework}.jsonl 의 각 행 구조.",
    "type": "object",
    "required": [
      "run_id","question_id","framework","dataset","task_type","run_index",
      "expected_answer","generated_answer","success",
      "input_tokens","output_tokens","total_tokens",
      "execution_time_sec","tool_calls","timestamp"
    ],
    "additionalProperties": false,
    "properties": {
      "run_id": {
        "type"       : "string",
        "pattern"    : "^Q\\d{3}_(LangChain|CrewAI|LangGraph)_\\d{2}$",
        "description": "실행 고유 ID. 형식: {question_id}_{framework}_{run_index:02d}. 예: Q001_LangChain_01"
      },
      "question_id": {
        "type"   : "string",
        "pattern": "^Q\\d{3}$"
      },
      "framework": {
        "type": "string",
        "enum": ["LangChain", "CrewAI", "LangGraph"]
      },
      "dataset": {
        "type": "string",
        "enum": ["Korean_Admin_QA", "FinQA"]
      },
      "task_type": {
        "type": "string",
        "enum": ["single_doc_extraction","complex_condition_judgment","single_evidence_numeric","multi_step_calculation"]
      },
      "run_index": {
        "type"       : "integer",
        "minimum"    : 1,
        "maximum"    : 3,
        "description": "반복 실행 회차. 1·2·3 중 하나."
      },
      "expected_answer": {
        "type"       : "string",
        "description": "gold_answers.csv의 expected_answer 값."
      },
      "generated_answer": {
        "type"       : "string",
        "description": "에이전트가 반환한 final_answer 값."
      },
      "success": {
        "type"       : "integer",
        "enum"       : [0, 1],
        "description": "과업 성공 여부. 1=성공, 0=실패. 판정 기준은 evaluation_rules.success_criteria 참조."
      },
      "input_tokens": {
        "type"       : "integer",
        "minimum"    : 0,
        "description": "LLM 호출 시 사용된 입력 토큰 합계."
      },
      "output_tokens": {
        "type"       : "integer",
        "minimum"    : 0,
        "description": "LLM 호출 시 생성된 출력 토큰 합계."
      },
      "total_tokens": {
        "type"       : "integer",
        "minimum"    : 0,
        "description": "input_tokens + output_tokens. 비용 지표의 기본 단위."
      },
      "execution_time_sec": {
        "type"       : "number",
        "minimum"    : 0.0,
        "description": "질의 1건 처리에 소요된 벽시계 시간(초). time.perf_counter() 기준."
      },
      "tool_calls": {
        "type"       : "integer",
        "minimum"    : 0,
        "maximum"    : 3,
        "description": "해당 실행에서 도구(retrieve_document / calculate / validate_output)를 호출한 총 횟수."
      },
      "timestamp": {
        "type"       : "string",
        "format"     : "date-time",
        "description": "실행 완료 시각. ISO 8601 UTC 형식. 예: 2026-05-06T09:00:00.000000Z"
      },
      "agent_response": {
        "type"       : ["object", "null"],
        "description": "(선택) 에이전트가 반환한 전체 응답 딕셔너리. agent_response_schema 형식."
      },
      "error_message": {
        "type"       : ["string", "null"],
        "description": "(선택) 실행 중 오류 발생 시 오류 메시지. 정상 실행 시 null."
      },
      "manual_review": {
        "type"       : ["string", "null"],
        "enum"       : ["pass", "fail", "partial", null],
        "description": "(선택) 연구자 수동 검수 결과. span_with_condition 과업 등 자동 판정 애매한 경우 사용."
      }
    },

    "example": {
      "run_id"            : "Q001_LangChain_01",
      "question_id"       : "Q001",
      "framework"         : "LangChain",
      "dataset"           : "Korean_Admin_QA",
      "task_type"         : "single_doc_extraction",
      "run_index"         : 1,
      "expected_answer"   : "44.9",
      "generated_answer"  : "44.9%",
      "success"           : 1,
      "input_tokens"      : 1240,
      "output_tokens"     : 218,
      "total_tokens"      : 1458,
      "execution_time_sec": 3.82,
      "tool_calls"        : 1,
      "timestamp"         : "2026-05-06T09:00:00.000000Z",
      "agent_response"    : null,
      "error_message"     : null,
      "manual_review"     : null
    }
  },

  "evaluation_rules": {
    "description": "과업 성공(success=1) 판정 기준, 지표 정의, 집계 방법, 수동 검수 기준.",

    "success_criteria": {
      "description": "과업 유형별 success=1 판정 기준. 자동 판정 후 수동 검수를 거친다.",

      "single_doc_extraction": {
        "answer_type"       : "span_extraction",
        "auto_method"       : "normalized_exact_match",
        "normalization_steps": [
          "양쪽 공백 제거 (strip)",
          "퍼센트 기호 제거 후 숫자만 비교 (예: '44.9%' → '44.9')",
          "천 단위 콤마 제거 (예: '4,273' → '4273')",
          "단위 문자열 분리 후 숫자 부분만 비교 (예: '4,273천원' → '4273')",
          "소문자 변환 (영문 혼용 대비)"
        ],
        "success_condition" : "정규화 후 generated_answer가 expected_answer를 포함하거나 완전 일치",
        "manual_review_trigger": "자동 판정 실패 시 연구자가 의미적 동일성 확인",
        "examples": [
          { "expected": "44.9",      "generated": "44.9%",     "result": 1, "reason": "숫자 부분 일치" },
          { "expected": "서울대공원", "generated": "서울대공원", "result": 1, "reason": "완전 일치" },
          { "expected": "4,273천원", "generated": "4273천원",   "result": 1, "reason": "콤마 제거 후 일치" },
          { "expected": "홍보전산과", "generated": "홍보팀",     "result": 0, "reason": "다른 기관명" }
        ]
      },

      "complex_condition_judgment": {
        "answer_type"       : "span_with_condition",
        "auto_method"       : "keyword_inclusion",
        "keyword_extraction": "expected_answer에서 핵심 명사구·동사구를 추출하여 generated_answer 내 포함 여부 확인",
        "success_condition" : "핵심 키워드 2개 이상이 generated_answer에 포함된 경우 자동 pass 후보로 분류. 최종 판정은 반드시 연구자 수동 검수.",
        "manual_review_trigger": "모든 complex_condition_judgment 문항에 대해 수동 검수 필수",
        "manual_review_criteria": [
          "정답의 핵심 조건·방법·절차가 빠짐없이 포함되어 있는가",
          "답변이 문서 내 근거에 기반하는가 (외부 지식 사용 여부)",
          "답변의 의미가 expected_answer와 동일한가 (표현이 달라도 의미 동일 시 pass)"
        ],
        "examples": [
          { "expected": "검사 및 상담 완료 후 검사결과를 아동 가구에 개별 통보", "generated": "검사와 상담을 마친 뒤 결과를 가구별로 개별 통보한다", "result": 1, "reason": "의미 동일 — 수동 pass" },
          { "expected": "관용차량 이용(총무팀 협조)",                           "generated": "대중교통을 이용한다",                               "result": 0, "reason": "수단 불일치" }
        ]
      },

      "single_evidence_numeric": {
        "answer_type"    : "numeric_calculation",
        "auto_method"    : "numeric_tolerance",
        "tolerance_rules": {
          "absolute": 0.01,
          "relative": 0.01,
          "description": "abs(generated - expected) ≤ 0.01  OR  abs(generated - expected) / abs(expected) ≤ 0.01 (1%) 중 하나를 만족하면 success=1",
          "special_cases": {
            "large_integers": "정수형 정답(예: 94, -35)은 절대 오차 ≤ 0.5 적용",
            "very_small_values": "|expected| < 0.001 이면 절대 오차 0.001 적용"
          }
        },
        "success_condition": "수치 허용오차 기준 충족 시 success=1",
        "manual_review_trigger": "is_answered=false이거나 generated_answer가 수치로 파싱 불가한 경우 수동 검수",
        "examples": [
          { "expected": "94.0",    "generated": "94",      "result": 1, "reason": "절대 오차 0 — 일치" },
          { "expected": "0.14464", "generated": "0.1446",  "result": 1, "reason": "절대 오차 0.00004 ≤ 0.01" },
          { "expected": "0.14464", "generated": "14.464",  "result": 0, "reason": "단위 오류 (퍼센트 혼동)" },
          { "expected": "-35.0",   "generated": "-35.001", "result": 1, "reason": "절대 오차 0.001 ≤ 0.01" }
        ]
      },

      "multi_step_calculation": {
        "answer_type"    : "numeric_multi_step",
        "auto_method"    : "numeric_tolerance",
        "tolerance_rules": {
          "absolute": 0.01,
          "relative": 0.01,
          "description": "단일 계산과 동일한 허용오차 적용. 단, 중간 단계 오차가 최종값에 누적되는 경우 허용오차를 단계 수만큼 합산 가능.",
          "step_tolerance": "각 중간 단계 결과의 허용오차는 0.001 (소수 셋째 자리)"
        },
        "success_condition": "최종값(final_answer)이 허용오차 기준 충족 시 success=1",
        "bonus_check": "calculation 필드의 계산 과정이 논리적으로 타당한지 연구자가 선택적으로 확인",
        "manual_review_trigger": "final_answer가 허용오차 기준에 근접하거나(오차 0.01~0.05) calculation 필드가 null인 경우",
        "examples": [
          { "expected": "0.09864", "generated": "0.0986",  "result": 1, "reason": "절대 오차 0.00004 ≤ 0.01" },
          { "expected": "705.25",  "generated": "705.3",   "result": 1, "reason": "절대 오차 0.05 — 허용오차 적용" },
          { "expected": "-0.04365","generated": "-0.0437", "result": 1, "reason": "절대 오차 0.00005 ≤ 0.01" }
        ]
      }
    },

    "metrics_definition": {
      "description": "논문 결과 섹션에 사용할 3개 핵심 지표의 정의 및 집계 방법.",

      "TSR": {
        "full_name"  : "Task Success Rate",
        "unit"       : "비율 (0.0~1.0)",
        "formula"    : "TSR = (success=1인 run 수) / (전체 run 수)",
        "aggregation": {
          "per_framework"     : "해당 프레임워크의 전체 run에서 TSR 계산",
          "per_dataset"       : "데이터셋별(Korean_Admin_QA / FinQA) 분리 집계",
          "per_task_type"     : "task_type별(4종) 분리 집계",
          "overall"           : "3회 반복의 평균 TSR을 프레임워크별로 비교"
        },
        "note": "3회 반복 실행의 평균을 사용한다. 단일 run 결과로 결론 도출 금지."
      },

      "Token_Usage": {
        "full_name"  : "Token Usage",
        "unit"       : "tokens (정수)",
        "sub_metrics": {
          "avg_input_tokens"  : "질의 1건당 평균 입력 토큰",
          "avg_output_tokens" : "질의 1건당 평균 출력 토큰",
          "avg_total_tokens"  : "질의 1건당 평균 전체 토큰 (주요 비교 지표)",
          "tokens_per_success": "성공한 질의 1건당 소요 토큰 = 전체 토큰 합 / success=1 건수"
        },
        "formula_tokens_per_success": "Tokens_per_Success = SUM(total_tokens) / SUM(success)",
        "note": "tokens_per_success는 '정답 1개를 얻기 위한 비용'을 나타내며 논문의 핵심 비용 지표로 사용한다."
      },

      "Execution_Time": {
